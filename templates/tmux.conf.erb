# Tmux color configuration
# Generated by Huebrew
# Palette: <%= palette.name %>
# Scheme: <%= palette.scheme %>

# Status bar
set -g status-style "bg=<%= colors['bgSubtle'] %>,fg=<%= colors['text'] %>"
set -g status-left-style "bg=<%= colors['solid'] %>,fg=<%= colors['bg'] %>"
set -g status-right-style "bg=<%= colors['bgSubtle'] %>,fg=<%= colors['textMuted'] %>"

# Window status
setw -g window-status-style "bg=<%= colors['bgSubtle'] %>,fg=<%= colors['textMuted'] %>"
setw -g window-status-current-style "bg=<%= colors['surface'] %>,fg=<%= colors['text'] %>"
setw -g window-status-activity-style "bg=<%= colors['surfaceActive'] %>,fg=<%= colors['solid'] %>"

# Pane borders
set -g pane-border-style "fg=<%= colors['border'] %>"
set -g pane-active-border-style "fg=<%= colors['solid'] %>"

# Message text
set -g message-style "bg=<%= colors['surface'] %>,fg=<%= colors['text'] %>"
set -g message-command-style "bg=<%= colors['surface'] %>,fg=<%= colors['text'] %>"

# Pane number display
set -g display-panes-active-colour "<%= colors['solid'] %>"
set -g display-panes-colour "<%= colors['textMuted'] %>"

# Clock
setw -g clock-mode-colour "<%= colors['solid'] %>"
